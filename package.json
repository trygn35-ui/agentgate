{
  "name": "agentgate",
  "version": "1.5.0",
  "author": "TRYGN",
  "private": true,
  "description": "A local API profile manager and loopback gateway for Claude Code, Codex, OpenCode and Gemini CLI.",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "dev:web": "vite --host 127.0.0.1",
    "build": "tsc --noEmit && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "dist": "pnpm build && electron-builder --win portable nsis --publish never",
    "dist:portable": "pnpm build && electron-builder --win portable",
    "release": "node scripts/release.mjs"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "electron-updater": "^6.8.9",
    "jsonc-parser": "^3.3.1",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "stream-json": "^1.9.1",
    "write-file-atomic": "^6.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@fontsource/eb-garamond": "^5.2.7",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "typescript": "~5.7.2",
    "vite": "^6.0.5",
    "vitest": "^2.1.8",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "dev.agentgate.desktop",
    "productName": "AgentGate",
    "asar": true,
    "publish": [
      {
        "provider": "github",
        "owner": "trygn35-ui",
        "repo": "agentgate"
      }
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "artifactName": "AgentGate-Setup-${version}-${arch}.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "portable": {
      "artifactName": "AgentGate-Portable-${version}-${arch}.${ext}"
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  }
}
